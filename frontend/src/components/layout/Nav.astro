---
---

<header id="main-nav" class="fixed top-0 left-0 w-full z-[100] transition-all duration-400 ease-smooth">
  <div class="max-w-[1920px] mx-auto px-8 md:px-16 py-6 flex items-center justify-between">
    <nav class="hidden md:flex items-center gap-8 font-body text-sm tracking-wider">
      <a href="/collections" class="hover:text-stone transition-colors duration-200" data-cursor="expand">Colecciones</a>
      <a href="/lookbook" class="hover:text-stone transition-colors duration-200" data-cursor="expand">Lookbook</a>
      <a href="/atelier" class="hover:text-stone transition-colors duration-200" data-cursor="expand">Atelier</a>
    </nav>

    <button class="md:hidden flex flex-col gap-[4px] p-2" aria-label="Open Menu">
      <span class="block w-5 h-[1px] bg-noir"></span>
      <span class="block w-5 h-[1px] bg-noir"></span>
    </button>

    <div class="absolute left-1/2 -translate-x-1/2">
      <a href="/" class="font-body text-[13px] tracking-widest uppercase font-medium" data-cursor="expand">
        Forma
      </a>
    </div>

    <div className="flex items-center gap-4">
      <a href="/cart" aria-label="Cart" class="p-2 hover:text-stone transition-colors duration-200" data-cursor="expand">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
      </a>
      <a href="/login" aria-label="Account" class="p-2 hover:text-stone transition-colors duration-200" data-cursor="expand">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  #main-nav.scrolled {
    background-color: rgba(245, 240, 234, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 0.5px solid var(--color-linen);
  }
</style>

<script>
  function handleScroll() {
    const nav = document.getElementById('main-nav');
    if (window.scrollY > 50) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
</script>
