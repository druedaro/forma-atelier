---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  schema?: string;
  fixedNav?: boolean;
  forceScrolled?: boolean;
}

const { 
  title, 
  description = 'Forma Atelier - Barcelona', 
  image,
  type,
  schema,
  fixedNav = false, 
  forceScrolled = false 
} = Astro.props;

import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

import SEO from '../components/seo/SEO.astro';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import { GlobalCart } from '../components/ui/GlobalCart';
import { WishlistDrawer } from '../components/wishlist/WishlistDrawer';
import { ErrorBoundary } from '../components/ui/ErrorBoundary';

import { BackToTop } from '../components/ui/BackToTop';
import SmoothScroll from '../components/layout/SmoothScroll';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO title={title} description={description} image={image} type={type} schema={schema} />
    <ClientRouter />

    <style is:inline>
      :root {
        --color-noir: #0A0A0A;
        --color-ivory: #F5F0EA;
        --color-gold: #C9A96E;
        --color-linen: #E8DDD0;
        --color-smoke: #F0EBE3;
        --font-display: 'Cormorant Garamond', Georgia, serif;
        --font-body: 'Jost', system-ui, sans-serif;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { background-color: #F5F0EA; -webkit-font-smoothing: antialiased; }
      body { font-family: 'Jost', system-ui, sans-serif; color: #0A0A0A; background-color: #F5F0EA; overflow-x: hidden; }
    </style>

    <script is:inline>
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
    </script>
    <slot name="head" />
  </head>
  <body>
    <div class="page-overlay"></div>
    <SmoothScroll client:load transition:persist="smooth-scroll" />
    <BackToTop client:load transition:persist="back-to-top" />
    <Nav fixedNav={fixedNav} forceScrolled={forceScrolled} transition:animate="none" />
    <div id="main-content" class="w-full" tabindex="-1">
      <slot />
    </div>
    <ErrorBoundary client:only="react">
      <GlobalCart client:only="react" />
    </ErrorBoundary>
    <ErrorBoundary client:only="react">
      <WishlistDrawer client:only="react" />
    </ErrorBoundary>

    <Footer transition:animate="none" />
  </body>
</html>
