---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ProductDetail } from '../../components/product/ProductDetail';
import { getProducts } from '../../lib/api/products';
import { mockProducts } from '../../lib/mock/data';

export async function getStaticPaths() {
  let products = await getProducts();
  if (products.length === 0) {
    products = mockProducts;
  }

  return products.map((product) => ({
    params: { id: product.slug }, 
    props: { product },
  }));
}

const { id } = Astro.params;
const { product } = Astro.props;

if (!product) {
  return Astro.redirect('/404');
}

const productSchema = JSON.stringify({
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": product.name,
  "image": product.images[0] ? `https://forma-atelier-bcn.vercel.app${product.images[0]}` : undefined,
  "description": product.description,
  "sku": product.id,
  "offers": {
    "@type": "Offer",
    "url": `https://forma-atelier-bcn.vercel.app/products/${product.slug}`,
    "priceCurrency": "EUR",
    "price": product.price,
    "availability": product.available ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
    "itemCondition": "https://schema.org/NewCondition"
  }
});
---

<BaseLayout 
  title={`FORMA ATELIER | ${product.name}`}
  description={product.description}
  image={product.images[0]}
  type="product"
  schema={productSchema}
>
  <main class="min-h-screen pt-24 bg-ivory">
    <ProductDetail product={product as any} client:load />
  </main>
</BaseLayout>
