---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Divider } from '../components/ui/Divider';
import { Button } from '../components/ui/Button';
---

<BaseLayout title="FORMA ATELIER | Contacto">
  <main class="pt-32 pb-24 px-8 md:px-16 min-h-screen bg-ivory">
    <div class="max-w-[800px] mx-auto">
      <header class="mb-16 text-center">
        <h1 class="font-display text-4xl md:text-5xl text-noir uppercase font-light tracking-widest mb-6">
          Contacto
        </h1>
        <p class="font-body text-sm text-stone leading-relaxed">
          Para consultas sobre nuestras colecciones, citas en el atelier o asistencia con tu pedido.
        </p>
      </header>

      <Divider className="mb-16" />

      <div id="form-success" class="hidden bg-[#F5F0EA] border border-gold text-noir p-6 mb-8 text-center font-body text-sm tracking-wide">
        Gracias por tu mensaje. Nos pondremos en contacto contigo lo antes posible.
      </div>

      <form id="contact-form" class="flex flex-col gap-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex flex-col gap-2">
            <label class="font-body text-[10px] uppercase tracking-widest text-stone">Nombre completo</label>
            <input 
              type="text"
              name="name" 
              required
              class="border-b-[0.5px] border-linen bg-transparent pb-2 font-body text-sm text-noir focus:outline-none focus:border-gold transition-colors rounded-none"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-body text-[10px] uppercase tracking-widest text-stone">Email</label>
            <input 
              type="email"
              name="email" 
              required
              class="border-b-[0.5px] border-linen bg-transparent pb-2 font-body text-sm text-noir focus:outline-none focus:border-gold transition-colors rounded-none"
            />
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label class="font-body text-[10px] uppercase tracking-widest text-stone">Asunto</label>
          <input 
            type="text"
            name="subject" 
            required
            class="border-b-[0.5px] border-linen bg-transparent pb-2 font-body text-sm text-noir focus:outline-none focus:border-gold transition-colors rounded-none"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label class="font-body text-[10px] uppercase tracking-widest text-stone">Mensaje</label>
          <textarea 
            name="message" 
            required
            rows={5}
            class="border-b-[0.5px] border-linen bg-transparent pb-2 font-body text-sm text-noir focus:outline-none focus:border-gold transition-colors rounded-none resize-none"
          ></textarea>
        </div>

        <div class="mt-8 text-center">
          <Button type="submit" variant="primary">Enviar Mensaje</Button>
        </div>
      </form>
    </div>
  </main>
</BaseLayout>

<script>
  import { db } from '../lib/firebase';
  import { collection, addDoc, serverTimestamp } from 'firebase/firestore';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
  
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Enviando...';
      }

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);
      
      // Basic sanitization to prevent XSS injection in any future processing
      const sanitize = (str: string) => {
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
      };

      const sanitizedData = {
        name: sanitize((data.name as string) || ''),
        email: sanitize((data.email as string) || ''),
        subject: sanitize((data.subject as string) || ''),
        message: sanitize((data.message as string) || ''),
        createdAt: serverTimestamp()
      };
      
      try {
        if (db) {
          await addDoc(collection(db, 'contacts'), sanitizedData);
        }
        
        if (successMsg) {
          successMsg.classList.remove('hidden');
        }
        form.reset();
      } catch (error) {
        console.error('Error enviando mensaje:', error);
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Enviar Mensaje';
        }
      }
    });
  }
</script>
