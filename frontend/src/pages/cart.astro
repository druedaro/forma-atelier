---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Divider } from '../components/ui/Divider';
import { CartPageContent } from '../components/cart/CartPageContent';
---

<BaseLayout title="FORMA ATELIER | Carrito">
  <main class="pt-32 pb-24 px-8 md:px-16 min-h-screen bg-[#F5F0EA]">
    <div class="max-w-[1400px] mx-auto">
      <header class="mb-12">
        <h1 class="font-display text-4xl text-[#0A0A0A] uppercase font-light tracking-widest mb-4">
          Cesta
        </h1>
        <Divider />
      </header>
      
      <CartPageContent client:load />
    </div>
  </main>
</BaseLayout>
