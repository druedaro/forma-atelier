---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CreativeHero } from '../components/home/CreativeHero';
import { HomeManifesto } from '../components/home/HomeManifesto';
import { HomeFeatured } from '../components/home/HomeFeatured';

const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "url": "https://forma-atelier-bcn.vercel.app/",
      "name": "Forma Atelier",
      "description": "Moda contemporánea y sastrería de diseño desde Barcelona."
    }
  ]
});
---

<BaseLayout 
  title="FORMA ATELIER | Redefiniendo la silueta moderna"
  type="website"
  schema={websiteSchema}
>
  <main>
    <CreativeHero client:load />
    <HomeManifesto client:load />
    <HomeFeatured client:load />
  </main>
</BaseLayout>
