---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { HorizontalGallery } from '../../components/lookbook/HorizontalGallery';
import { getLooks } from '../../lib/api/looks';
import { mockLooks, mockCollections } from '../../lib/mock/data';

let allLooks = await getLooks();
if (allLooks.length === 0) {
  allLooks = mockLooks;
}

// Create a map of collection id to slug
const collectionSlugs = mockCollections.reduce((acc, col) => {
  acc[col.id] = col.slug;
  return acc;
}, {} as Record<string, string>);
---

<BaseLayout title="FORMA ATELIER | Lookbook">
  <main class="bg-noir min-h-screen">
    <HorizontalGallery looks={allLooks as any} collectionSlugs={collectionSlugs} client:load />
  </main>
</BaseLayout>
