---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Button } from '../components/ui/Button';
---

<BaseLayout title="FORMA ATELIER | 404">
  <main class="min-h-screen pt-32 pb-16 px-8 md:px-16 bg-ivory flex flex-col items-center justify-center text-center">
    <h1 class="font-display text-8xl md:text-9xl text-noir font-light mb-4 tracking-widest">
      404
    </h1>
    <h2 class="font-display text-2xl uppercase tracking-widest text-noir font-light mb-8">
      Página no encontrada
    </h2>
    <p class="font-body text-stone tracking-wider max-w-md mx-auto mb-12 text-sm">
      Lo sentimos, no hemos podido encontrar la página que buscas. Es posible que haya sido movida o eliminada.
    </p>
    
    <a href="/" data-cursor="expand">
      <Button client:visible>Volver al inicio</Button>
    </a>
  </main>
</BaseLayout>
