---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LoginForm } from '../components/auth/LoginForm';
---

<BaseLayout title="FORMA ATELIER | Acceder">
  <main class="min-h-screen pt-32 pb-16 px-8 md:px-16 bg-ivory flex items-center justify-center">
    <div class="max-w-md w-full bg-ivory shadow-xl p-8 border-[0.5px] border-linen">
      <h1 class="font-display text-2xl uppercase tracking-widest text-noir font-light mb-8 text-center">
        Acceder
      </h1>
      <LoginForm client:load />
    </div>
  </main>
</BaseLayout>
