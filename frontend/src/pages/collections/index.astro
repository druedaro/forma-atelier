---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollections } from '../../lib/api/collections';
import { mockCollections } from '../../lib/mock/data';
import { Divider } from '../../components/ui/Divider';

let collections = await getCollections();
if (collections.length === 0) {
  collections = mockCollections;
}
---

<BaseLayout title="FORMA ATELIER | Colecciones">
  <main class="pt-32 pb-24 px-8 md:px-16 min-h-screen bg-ivory">
    <div class="max-w-[1920px] mx-auto">
      <header class="mb-16">
        <h1 class="font-display text-5xl md:text-7xl text-noir uppercase font-light tracking-widest mb-6">
          Colecciones
        </h1>
        <p class="font-body text-sm text-stone max-w-xl leading-relaxed">
          Un archivo de nuestras obras pasadas y presentes. Cada colección explora una narrativa única a través de la arquitectura del tejido y el estudio de la forma.
        </p>
      </header>

      <Divider className="mb-16" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-x-12 md:gap-y-24">
        {collections.map((collection, index) => (
          <a 
            href={`/collections/${collection.slug}`} 
            class="group w-full flex flex-col gap-6"
            data-cursor="text"
            data-cursor-text="Explorar"
          >
            <div class="relative w-full aspect-[4/5] overflow-hidden bg-smoke">
              <img 
                src={collection.hero_image} 
                alt={collection.name}
                class="w-full h-full object-cover transition-transform duration-[1.2s] group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-noir/10 group-hover:bg-transparent transition-colors duration-700"></div>
            </div>

            <div class="flex flex-col gap-2">
              <div class="flex justify-between items-end">
                <h2 class="font-display text-3xl uppercase tracking-widest text-noir font-light">
                  {collection.name}
                </h2>
                <span class="font-body text-xs text-stone tracking-wider uppercase">
                  {collection.season}
                </span>
              </div>
              <p class="font-body text-xs text-stone leading-relaxed line-clamp-2">
                {collection.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
