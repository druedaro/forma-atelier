# ─────────────────────────────────────────────────────────────────────────────
# Forma Atelier — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# En Vercel, configura estas variables en Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase (cliente — todas son públicas, van en el bundle del navegador)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# Stripe — clave pública (va en el bundle del navegador)
PUBLIC_STRIPE_KEY=pk_test_...

# Stripe — clave secreta (NUNCA al repositorio, solo servidor/Vercel)
# Configúrala como variable sensible en el panel de Vercel
STRIPE_SECRET_KEY=sk_test_...
